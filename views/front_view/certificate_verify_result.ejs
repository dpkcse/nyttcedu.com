<%- include('layouts/head') %>
<%- include('layouts/top_navbar') %>

<section>
  <div class="container">
    <div class="row">
      <div class="col-lg-12">
        <div class="bg-light-violet p-4">
          <h4 class="text-center p-2 verify-rslt">Certificate Verification</h4>
          <% if (certificate) { %>
            <div class="alert alert-success text-center">Verified Certificate</div>
            <div class="table-responsive">
              <table class="table table-dark-violet">
                <tr><td class="first-col">Serial No</td><td class="middle-col">:</td><td class="second-col"><%= certificate.serial_no %></td></tr>
                <tr><td class="first-col">Student Name</td><td class="middle-col">:</td><td class="second-col"><%= certificate.s_name %></td></tr>
                <tr><td class="first-col">Course</td><td class="middle-col">:</td><td class="second-col"><%= certificate.course_title %></td></tr>
                <tr><td class="first-col">Session</td><td class="middle-col">:</td><td class="second-col"><%= certificate.session %></td></tr>
                <tr><td class="first-col">Passing Year</td><td class="middle-col">:</td><td class="second-col"><%= certificate.passing_year %></td></tr>
                <tr><td class="first-col">Result / CGPA</td><td class="middle-col">:</td><td class="second-col"><%= certificate.result %></td></tr>
                <tr><td class="first-col">Issue Date</td><td class="middle-col">:</td><td class="second-col"><%= certificate.issue_date ? moment(certificate.issue_date).format('LL') : 'N/A' %></td></tr>
              </table>
            </div>
          <% } else { %>
            <div class="alert alert-danger text-center"><%= errMsg %></div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('layouts/footer') %>
<%- include('layouts/sign_in_up_modal') %>
<%- include('layouts/foot') %>
