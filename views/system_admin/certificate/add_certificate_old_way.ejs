<%- include('../system_layouts/s_head') %>

<div class="container-fluid">
  <%- include('../system_layouts/s_breadcumb') %>
  <div class="row">
    <div class="col-xl-12">
      <div class="card">
          <div class="card-body">
							<h4 class="card-title">Add New - Certifate Info || As old way</h4>
							<% if(sucMsg != ''){ %>
								<div class="alert alert-success alert-dismissable">
										<button aria-hidden="true" class="close" data-dismiss="alert" type="button">×</button>
										<%= sucMsg %>
								</div>
							<% } %>
							<% if(errMsg != ''){ %>
								<div class="alert alert-danger alert-dismissable">
										<button aria-hidden="true" class="close" data-dismiss="alert" type="button">×</button>
										<%= errMsg %>
								</div>
							<% } %>
              <!-- <p class="card-title-desc">Provide valuable, actionable feedback to your users with HTML5 form validation–available in all our supported browsers.</p> -->
              <form method="post" action="/certificate/add-certificate-old-way" autocomplete="off">
                <div class="row">
									<div class="col-md-4">
										<div class="form-group">
											<label for="name">Student's Name <span class="mendatory">*</span></label>
											<input type="text" name="name" class="form-control" id="name" placeholder="Students's Name" value="" required="">
										</div>
									</div>
									<div class="col-md-4">
											<div class="form-group">
													<label for="fathers_name">Father's Name <span class="mendatory">*</span></label>
													<input type="text" name="fathers_name" class="form-control" id="fathers_name" placeholder="Father's Name" value="" required="">
											</div>
									</div>
									<div class="col-md-4">
										<div class="form-group">
											<label for="mothers_name">Mother's Name <span class="mendatory">*</span></label>
											<input type="text" name="mothers_name" class="form-control" id="mothers_name" placeholder="Mother's Name" value="" required="">
										</div>
									</div>
                    <div class="col-md-2">
                        <div class="form-group">
                        		<label for="serial_no">Serial No <span class="mendatory">*</span></label>
                            <input type="text" name="serial_no" class="form-control" id="serial_no" placeholder="Serial No" value="" required="" onkeypress="return (event.charCode >= 48 && event.charCode <= 57) ||  event.charCode == 45 || (event.charCode >= 65 && event.charCode <= 90)">
                            <!-- <input type="text" name="serial_no" class="form-control" id="serial_no" placeholder="Serial No" value="" required=""> -->
                        </div>
                    </div>
                    
										<div class="col-md-2">
											<div class="form-group">
												<label for="session">Session <span class="mendatory">*</span></label>
												<input type="text" name="session" class="form-control" id="session" placeholder="Session" value="" required="">
											</div>
										</div>
										<div class="col-md-4">
											<div class="form-group">
												<label for="course_title">Course Title <span class="mendatory">*</span></label>
												<input type="text" name="course_title" class="form-control" id="course_title" placeholder="Course Title" value="" required="">
											</div>
										</div>
										<div class="col-md-2">
											<div class="form-group">
												<label for="passing_year">Passing Year <span class="mendatory">*</span></label>
												<input type="text" name="passing_year" class="form-control" id="passing_year" placeholder="Passing Year" value="" required="" onkeypress="return event.charCode >= 48 && event.charCode <= 57">
											</div>
										</div>
										<div class="col-md-2">
											<div class="form-group">
												<label for="result">Result <span class="mendatory">*</span></label>
												<input type="text" name="result" class="form-control" id="result" placeholder="Result" value="" required="">
											</div>
										</div>
                </div>
                <br>
                <div class="text-center">
										<button class="btn btn-primary certificateOldBtn" type="submit" name="saveUpdate" id="courseCertificateBtn">Save Certificate</button>
										<button class="btn btn-danger certificateOldBtn" type="reset" id="resetBtn">Reset</button>
                </div>
						</form>
						<!-- <form action="/certificate" method="post">
							<button class="btn btn-primary certificateOldBtn" type="submit" name="name" id="courseCertificateBtn" value="ReSave">ReSave</button>
						</form> -->
          </div>
      </div>
    </div>
	</div>
	
	<div class="row">
		<div class="col-12">
			<div class="card">
				<div class="card-body">
					<h4 class="card-title">Last 50 Certificate Lists</h4>
					<p class="card-title-desc">
						In here, showing last 50 issued certificate lists.
					</p>	
					<table id="datatable-buttons" class="table table-striped table-bordered dt-responsive nowrap" style="border-collapse: collapse; border-spacing: 0; width: 100%;">
						<thead>
							<tr>
								<th>Sl</th>
								<th>Serial</th>
								<th>Student Name</th>
								<th>Fathers Name</th>
								<th>Mothers Name</th>
								<th>Course Title</th>
								<th>Session</th>
								<th>Passing Year</th>
								<th>Result</th>
								<!-- <th>Action</th> -->
							</tr>
						</thead>
						<tbody>
							<% _.each(old_certificates, function(v, k) { %>
								<tr>
									<td><%= (k+1) %></td>
									<td><%= v.serial_no %></td>
									<td><%= v.s_name %></td>
									<td><%= v.f_name %></td>
									<td><%= v.m_name %></td>
									<td><%= v.session %></td>
									<td><%= v.course_title %></td>
									<td><%= v.passing_year %></td>
									<td><%= v.result %></td>
									<!-- <td></td> -->
								</tr>
							<% }); %>
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>
	

</div>

<%- include('../system_layouts/s_foot') %>