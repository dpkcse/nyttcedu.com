<%- include('../system_layouts/s_head') %>

<div class="container-fluid">
  <%- include('../system_layouts/s_breadcumb') %>
  <div class="row">
    <div class="col-xl-12">
      <div class="card">
          <div class="card-body">
							<% if(Object.keys(old_certificates).length != 0) { %>
								<h4 class="card-title">Update Old - Certifate Info || Using old way</h4>
							<% } %>
							<% if(sucMsg != ''){ %>
								<div class="alert alert-success alert-dismissable">
										<button aria-hidden="true" class="close" data-dismiss="alert" type="button">×</button>
										<%= sucMsg %>
								</div>
							<% } %>
							<% if(errMsg != ''){ %>
								<div class="alert alert-danger alert-dismissable">
										<button aria-hidden="true" class="close" data-dismiss="alert" type="button">×</button>
										<%= errMsg %>
								</div>
							<% } %>
              <!-- <p class="card-title-desc">Provide valuable, actionable feedback to your users with HTML5 form validation–available in all our supported browsers.</p> -->
              
							<% if(Object.keys(old_certificates).length != 0) { %>
								<form method="post" action="/certificate/update-certificate-old-way" autocomplete="off">
									<div class="row">
										<div class="col-md-4">
											<div class="form-group">
												<label for="name">Student's Name <span class="mendatory">*</span></label>
												<input type="text" name="name" class="form-control" id="name" placeholder="Students's Name" value="<%= old_certificates.s_name %>" required="">
											</div>
										</div>
										<div class="col-md-4">
												<div class="form-group">
														<label for="fathers_name">Father's Name <span class="mendatory">*</span></label>
														<input type="text" name="fathers_name" class="form-control" id="fathers_name" placeholder="Father's Name" value="<%= old_certificates.f_name %>" required="">
												</div>
										</div>
										<div class="col-md-4">
											<div class="form-group">
												<label for="mothers_name">Mother's Name <span class="mendatory">*</span></label>
												<input type="text" name="mothers_name" class="form-control" id="mothers_name" placeholder="Mother's Name" value="<%= old_certificates.m_name %>" required="">
											</div>
										</div>
											<div class="col-md-2">
													<div class="form-group">
															<label for="serial_no">Serial No <span class="mendatory">*</span></label>
															<input type="text" name="serial_no" class="form-control" id="serial_no" placeholder="Serial No" value="<%= old_certificates.serial_no %>" required="" onkeypress="return event.charCode >= 48 && event.charCode <= 57" readonly>
													</div>
											</div>
											
											<div class="col-md-2">
												<div class="form-group">
													<label for="session">Session <span class="mendatory">*</span></label>
													<input type="text" name="session" class="form-control" id="session" placeholder="Session" value="<%= old_certificates.session %>" required="">
												</div>
											</div>
											<div class="col-md-4">
												<div class="form-group">
													<label for="course_title">Course Title <span class="mendatory">*</span></label>
													<input type="text" name="course_title" class="form-control" id="course_title" placeholder="Course Title" value="<%= old_certificates.course_title %>" required="">
												</div>
											</div>
											<div class="col-md-2">
												<div class="form-group">
													<label for="passing_year">Passing Year <span class="mendatory">*</span></label>
													<input type="text" name="passing_year" class="form-control" id="passing_year" placeholder="Passing Year" value="<%= old_certificates.passing_year %>" required="" onkeypress="return event.charCode >= 48 && event.charCode <= 57">
												</div>
											</div>
											<div class="col-md-2">
												<div class="form-group">
													<label for="result">Result <span class="mendatory">*</span></label>
													<input type="text" name="result" class="form-control" id="result" placeholder="Result" value="<%= old_certificates.result %>" required="">
												</div>
											</div>
									</div>
									<br>
									<div class="text-center">
											<input type="hidden" name="id" value="<%= old_certificates.id %>" required="">
											<button class="btn btn-primary updateCertOldBtn" type="submit" name="saveUpdate" id="updateCertificateBtn">Update Certificate</button>
											<a href="/certificate/search-old-way" class="btn btn-danger updateCertOldBtn">Cancel</a>
									</div>
								</form>
							<% } %>
          </div>
      </div>
    </div>
	</div>
	
	<div class="row">
		<div class="col-12">
			<div class="card">
				<div class="card-body">
					<h4 class="card-title">Last updated 1 Certificate information</h4>
					<p class="card-title-desc">
						In here, showing last updated certificate information.
					</p>	
					<table id="datatable-buttons" class="table table-striped table-bordered dt-responsive nowrap" style="border-collapse: collapse; border-spacing: 0; width: 100%;">
						<thead>
							<tr>
								<th>Sl</th>
								<th>Serial</th>
								<th>Student Name</th>
								<th>Fathers Name</th>
								<th>Mothers Name</th>
								<th>Course Title</th>
								<th>Session</th>
								<th>Passing Year</th>
								<th>Result</th>
								<!-- <th>Action</th> -->
							</tr>
						</thead>
						<tbody>
							<% if(Object.keys(update_cert_info).length != 0) { %>
								<td>1</td>
								<td><%= update_cert_info.serial_no %></td>
								<td><%= update_cert_info.s_name %></td>
								<td><%= update_cert_info.f_name %></td>
								<td><%= update_cert_info.m_name %></td>
								<td><%= update_cert_info.course_title %></td>
								<td><%= update_cert_info.session %></td>
								<td><%= update_cert_info.passing_year %></td>
								<td><%= update_cert_info.result %></td>
							<% } %>
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>
	

</div>

<%- include('../system_layouts/s_foot') %>