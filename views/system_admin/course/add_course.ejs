<%- include('../system_layouts/s_head') %>

<div class="container-fluid">
  <%- include('../system_layouts/s_breadcumb') %>
  <div class="row">
    <div class="col-xl-12">
      <div class="card">
          <div class="card-body">
              <h4 class="card-title">Add New - Course Info</h4>
              <!-- <p class="card-title-desc">Provide valuable, actionable feedback to your users with HTML5 form validation–available in all our supported browsers.</p> -->
              <form method="post" action="/course/add-course">
                <div class="row">
                    
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="course_title">Course Title</label>
                            <input type="text" name="course_title" class="form-control" id="course_title" placeholder="Course Title" value="" required="">
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label for="short_title">Short Title</label>
                            <input type="text" name="short_title" class="form-control" id="short_title" placeholder="Course Short Title" value="N/A" required="">
                        </div>
										</div>
										
										<div class="col-md-3">
												<div class="form-group">
														<label for="course_fee">Course Fee</label>
														<input type="text" name="course_fee" class="form-control" id="course_fee" placeholder="Course Fee" value="0" required="" onkeypress="return event.charCode >= 48 && event.charCode <= 57">
												</div>
										</div>
										<div class="col-md-3">
											<div class="form-group">
													<label for="registration_fee">Registration Fee</label>
													<input type="text" name="registration_fee" class="form-control" id="registration_fee" placeholder="Registraion Fee" value="0" required="" onkeypress="return event.charCode >= 48 && event.charCode <= 57">
											</div>
										</div>
                </div>

                <div class="row">
                    <div class="col-lg-2">
                        <div class="form-group">
                            <label for="course_type">Course Type</label>
                            <select name="course_type" id="course_type" class="form-control" required="">
                              <option value="">Select one...</option>
                              <option value="1">Short Course</option>
                              <option value="2">Long Course</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="form-group">
                            <label for="course_duration_id">Course Duration</label>
                            <select name="course_duration_id" id="course_duration_id" class="form-control" required="">
                              <option value="">Select one...</option>
															<% _.each(course_duration, (v, k) => { %>
																<option value="<%= v.course_duration_id %>"><%= v.duration_title %></option>
															<% }); %>
                            </select>
                        </div>
                    </div>
                    
                    <div class="col-lg-4">
                        <div class="form-group">
                            <label for="department_id">Department</label>
                            <select name="department_id" id="department_id" class="form-control" required="">
                              <option value="">Select one...</option>
															<% _.each(department, (v, k) => { %>
																<option value="<%= v.department_id %>"><%= v.department_name %></option>
															<% }); %>
                            </select>
                        </div>
                    </div>

										<div class="col-md-2">
											<div class="form-group">
													<label for="sequence">Sequence</label>
													<select name="sequence" id="sequence" class="form-control" disabled>
														<option value="">Select one...</option>
														<option value="1">1</option>
														<option value="2">2</option>
													</select>
											</div>
										</div>
                </div>
                <br>
                <div class="text-center">
										<button class="btn btn-primary courseBtn" type="submit" name="saveUpdate" id="courseSaveUpdateBtn" disabled>Save Course</button>
										<button class="btn btn-danger courseBtn" type="reset" id="CourseResetBtn">Reset</button>
                </div>
            </form>
          </div>
      </div>
    </div>
	</div>
	
	<div class="row">
		<div class="col-12">
			<div class="card">
				<div class="card-body">
					<h4 class="card-title">All Course Lists</h4>
					<p class="card-title-desc">
						In here, showing all course lists.
					</p>
	
					<table id="datatable-buttons-length" class="table table-striped table-bordered dt-responsive nowrap" style="border-collapse: collapse; border-spacing: 0; width: 100%;">
						<thead>
							<tr>
								<th>Sl</th>
								<th>Type</th>
								<th>Department</th>
								<th>S</th>
								<th>Course Title</th>
								<th>Short Title</th>
								<th>Duration</th>
								<th>Status</th>
								<th>Action</th>
							</tr>
						</thead>
	
						<tbody>
							<% _.each(allCourseList, (v, k) => { %>
								<tr>
									<td><%= (k+1) %></td>
									<td><%= v.course_type_text %></td>
									<td><%= v.department_name %></td>
									<td>
										<%= v.sequence %>
										&nbsp;&nbsp;
										<div class="btn-group">
											<button type="button" class="btn btn-sm btn-secondary" style="padding: 0 .15rem;"><span class="bx bxs-up-arrow-square"></span></button>
											<button type="button" class="btn btn-sm btn-secondary" style="padding: 0 .15rem;"><span class="bx bxs-down-arrow-square"></span></button>
										</div>
										
									</td>
									<td><%= v.course_title %></td>
									<td><%= v.short_title %></td>
									<td><%= v.course_duration_text %></td>
									<td>
											<% if(v.status == 1) { %>
												<div class="bg-success btn-sm text-center text-white"><%= v.status_text %></div>
											<% } else { %>
												<div class="bg-danger btn-sm text-center text-white"><%= v.status_text %></div>
											<% } %>
									</td>
									<td>
										<div class="btn-group btn-group-sm">
												<button type="button" class="btn btn-primary">													
													<span class="bx bxs-edit-alt"></span>
												</button>
												<button type="button" class="btn btn-warning">
													<% if(v.status == 1) { %>
														<span class="bx bxs-hide"></span>
													<% } else { %>
														<span class="bx bxs-show"></span>
													<% } %>
												</button>
												<button type="button" class="btn btn-danger">
													<i class="mdi mdi-delete"></i>
												</button>
										</div>
									</td>
								</tr>
							<% }); %>
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>
	

</div>

<%- include('../system_layouts/s_foot') %>