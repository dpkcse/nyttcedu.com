<%- include('system_layouts/s_head') %>
<div class="container-fluid">
        <%- include('system_layouts/s_breadcumb') %>
        <%- include('system_layouts/s_message') %>
        <div class="card shadow-sm">
          <div class="card-body">
            <h4 class="card-title mb-3">Student Photo Management</h4>
            <p class="text-muted">Search by exact or partial Serial Number / Student Name, then verify details before updating the photo.</p>
            <form id="studentPhotoSearchForm" class="form-row align-items-end">
              <div class="col-md-9 mb-2">
                <label for="studentSearch">Search Student</label>
                <input type="text" id="studentSearch" class="form-control" placeholder="Search by Serial Number or Student Name" autocomplete="off" />
                <small class="form-text text-muted">Enter at least 2 characters. Exact serial number matches are shown first.</small>
              </div>
              <div class="col-md-3 mb-2">
                <button id="searchBtn" type="submit" class="btn btn-primary btn-block">Search Student</button>
              </div>
            </form>
            <div id="searchAlert" class="alert d-none mt-3"></div>
          </div>
        </div>

        <div class="card shadow-sm">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2">
              <h5 class="mb-0">Search Results</h5>
              <span id="resultCount" class="badge badge-secondary">0</span>
            </div>
            <div class="table-responsive">
              <table class="table table-bordered table-hover mb-0">
                <thead class="thead-light">
                  <tr>
                    <th>Photo</th><th>Serial Number</th><th>Registration Number</th><th>Student Name</th><th>Father's Name</th><th>Course / Trade</th><th>Session</th><th>Status</th><th>Action</th>
                  </tr>
                </thead>
                <tbody id="resultsBody"><tr><td colspan="9" class="text-center text-muted">No search executed.</td></tr></tbody>
              </table>
            </div>
          </div>
        </div>

        <div id="managePanel" class="card shadow-sm d-none">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-center flex-wrap">
              <h5 class="mb-2">Manage Photo</h5>
              <button type="button" id="cancelManage" class="btn btn-light btn-sm">Cancel</button>
            </div>
            <div id="manageAlert" class="alert d-none"></div>
            <div class="row">
              <div class="col-lg-7">
                <div class="table-responsive">
                  <table class="table table-sm table-bordered">
                    <tbody id="studentInfo"></tbody>
                  </table>
                </div>
              </div>
              <div class="col-lg-5">
                <div class="row">
                  <div class="col-sm-6 text-center mb-3">
                    <strong>Current Photo</strong>
                    <div id="currentPhoto" class="border rounded p-2 mt-2 photo-box">No student photo uploaded</div>
                  </div>
                  <div class="col-sm-6 text-center mb-3">
                    <strong>New Photo Preview</strong>
                    <div id="newPreview" class="border rounded p-2 mt-2 photo-box text-muted">No new photo selected</div>
                  </div>
                </div>
                <% if (can_manage_photos) { %>
                <form id="photoForm" enctype="multipart/form-data">
                  <input type="file" name="photo" id="photoInput" class="form-control-file" accept="image/jpeg,image/png,image/webp" />
                  <small class="form-text text-muted mb-3">Recommended: passport-style photo, 3:4 ratio, JPG/PNG/WEBP, maximum 2 MB.</small>
                  <button type="submit" id="savePhoto" class="btn btn-success">Save Photo</button>
                  <button type="button" id="clearSelection" class="btn btn-secondary">Cancel</button>
                  <button type="button" id="removePhoto" class="btn btn-danger d-none">Remove Photo</button>
                </form>
                <% } else { %>
                  <div class="alert alert-warning">You do not have permission to upload, replace, or remove photos.</div>
                <% } %>
              </div>
            </div>
          </div>
        </div>
</div>
<style>
.photo-thumb{width:54px;height:72px;object-fit:cover;border-radius:4px}.photo-box{min-height:170px;display:flex;align-items:center;justify-content:center;overflow:hidden}.photo-box img{max-width:100%;max-height:260px;object-fit:contain}@media(max-width:575px){.photo-box{min-height:130px}.btn{margin-bottom:6px}}
</style>
<script>
document.addEventListener('DOMContentLoaded', function () {
  var selectedStudent = null;
  var activeSearchController = null;
  var isSearchLoading = false;

  var searchForm = document.getElementById('studentPhotoSearchForm');
  var searchInput = document.getElementById('studentSearch');
  var searchBtn = document.getElementById('searchBtn');
  var searchAlert = document.getElementById('searchAlert');
  var resultCount = document.getElementById('resultCount');
  var resultsBody = document.getElementById('resultsBody');
  var managePanel = document.getElementById('managePanel');
  var manageAlert = document.getElementById('manageAlert');
  var studentInfo = document.getElementById('studentInfo');
  var currentPhoto = document.getElementById('currentPhoto');
  var newPreview = document.getElementById('newPreview');
  var photoForm = document.getElementById('photoForm');
  var photoInput = document.getElementById('photoInput');
  var savePhoto = document.getElementById('savePhoto');
  var clearSelection = document.getElementById('clearSelection');
  var cancelManage = document.getElementById('cancelManage');
  var removePhoto = document.getElementById('removePhoto');

  if (!searchForm || !searchInput || !searchBtn || !searchAlert || !resultCount || !resultsBody) {
    console.error('Student Photo Management search form elements were not found.');
    return;
  }

  function setText(el, value) {
    if (el) el.textContent = value == null ? '' : String(value);
  }

  function clearChildren(el) {
    if (!el) return;
    while (el.firstChild) el.removeChild(el.firstChild);
  }

  function setAlert(el, type, message) {
    if (!el) return;
    el.classList.remove('d-none', 'alert-success', 'alert-danger', 'alert-warning', 'alert-info');
    el.classList.add('alert-' + type);
    setText(el, message);
  }

  function clearAlert(el) {
    if (!el) return;
    el.classList.add('d-none');
    setText(el, '');
  }

  function appendNoPhoto(el, label) {
    clearChildren(el);
    var span = document.createElement('span');
    span.className = 'text-muted';
    span.textContent = label || 'No student photo uploaded';
    el.appendChild(span);
  }

  function appendImage(el, src, alt, className) {
    clearChildren(el);
    var img = document.createElement('img');
    if (className) img.className = className;
    img.src = src;
    img.alt = alt;
    el.appendChild(img);
  }

  function renderPlaceholder(message) {
    clearChildren(resultsBody);
    var tr = document.createElement('tr');
    var td = document.createElement('td');
    td.colSpan = 9;
    td.className = 'text-center text-muted';
    td.textContent = message;
    tr.appendChild(td);
    resultsBody.appendChild(tr);
  }

  function renderRows(rows) {
    var safeRows = Array.isArray(rows) ? rows : [];
    resultCount.textContent = String(safeRows.length);
    clearChildren(resultsBody);
    if (!safeRows.length) {
      renderPlaceholder('No results found.');
      return;
    }
    safeRows.forEach(function (student) {
      var tr = document.createElement('tr');
      var values = [student.serial_no, student.registration_no, student.s_name, student.f_name, student.course_title, student.session, student.status];
      var photoTd = document.createElement('td');
      if (student.photo_url) appendImage(photoTd, student.photo_url, 'Student photo', 'photo-thumb');
      else appendNoPhoto(photoTd, 'No photo');
      tr.appendChild(photoTd);
      values.forEach(function (value) {
        var td = document.createElement('td');
        td.textContent = value == null ? '' : String(value);
        tr.appendChild(td);
      });
      var actionTd = document.createElement('td');
      var button = document.createElement('button');
      button.type = 'button';
      button.className = 'btn btn-info btn-sm manage-btn';
      button.dataset.id = student.id;
      button.textContent = 'Manage Photo';
      actionTd.appendChild(button);
      tr.appendChild(actionTd);
      resultsBody.appendChild(tr);
    });
  }

  async function parseJsonResponse(response, fallbackMessage) {
    var payload = {};
    try { payload = await response.json(); } catch (err) { payload = {}; }
    if (!response.ok) throw new Error(payload.message || payload.errMsg || fallbackMessage);
    return payload;
  }

  async function searchStudents(query, signal) {
    var response = await fetch('/certificate/student-photos/search?q=' + encodeURIComponent(query), {
      method: 'GET',
      headers: { Accept: 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      credentials: 'same-origin',
      signal: signal
    });
    return parseJsonResponse(response, 'Student search failed.');
  }

  async function loadStudent(studentId) {
    var response = await fetch('/certificate/student-photos/' + encodeURIComponent(studentId), {
      method: 'GET',
      headers: { Accept: 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      credentials: 'same-origin'
    });
    return parseJsonResponse(response, 'Student record was not found.');
  }

  async function saveStudentPhoto(studentId, file) {
    var formData = new FormData();
    formData.append('photo', file);
    var response = await fetch('/certificate/student-photos/' + encodeURIComponent(studentId) + '/photo', {
      method: 'POST',
      headers: { Accept: 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      credentials: 'same-origin',
      body: formData
    });
    return parseJsonResponse(response, 'Photo update failed. The existing photo was not changed.');
  }

  async function deleteStudentPhoto(studentId) {
    var response = await fetch('/certificate/student-photos/' + encodeURIComponent(studentId) + '/photo', {
      method: 'DELETE',
      headers: { Accept: 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      credentials: 'same-origin'
    });
    return parseJsonResponse(response, 'Server error.');
  }

  function renderStudentInfo(student) {
    if (!studentInfo) return;
    clearChildren(studentInfo);
    [
      ['serial_no', 'Serial Number'], ['registration_no', 'Registration Number'], ['s_name', 'Student Name'],
      ['f_name', 'Father\'s Name'], ['m_name', 'Mother\'s Name'], ['course_title', 'Course / Trade'],
      ['session', 'Session'], ['result', 'Result / Status']
    ].forEach(function (item) {
      var tr = document.createElement('tr');
      var th = document.createElement('th');
      var td = document.createElement('td');
      th.textContent = item[1];
      td.textContent = student[item[0]] == null ? '' : String(student[item[0]]);
      tr.appendChild(th);
      tr.appendChild(td);
      studentInfo.appendChild(tr);
    });
  }

  function clearSelectedFile() {
    if (photoInput) photoInput.value = '';
    if (newPreview) appendNoPhoto(newPreview, 'No new photo selected');
  }

  searchForm.addEventListener('submit', async function (event) {
    event.preventDefault();
    if (isSearchLoading) return;
    clearAlert(searchAlert);
    var query = searchInput.value.trim();
    if (!query) return setAlert(searchAlert, 'warning', 'Search term is required.');
    if (query.length < 2) return setAlert(searchAlert, 'warning', 'Please enter at least 2 characters.');
    isSearchLoading = true;
    if (activeSearchController) activeSearchController.abort();
    activeSearchController = new AbortController();
    searchBtn.disabled = true;
    searchBtn.textContent = 'Searching...';
    renderPlaceholder('Loading...');
    try {
      var payload = await searchStudents(query, activeSearchController.signal);
      var rows = payload.result || [];
      renderRows(rows);
      if (!rows.length) setAlert(searchAlert, 'info', payload.sucMsg || 'No students found.');
    } catch (err) {
      if (err.name !== 'AbortError') {
        renderRows([]);
        setAlert(searchAlert, 'danger', err.message || 'Server error.');
      }
    } finally {
      isSearchLoading = false;
      searchBtn.disabled = false;
      searchBtn.textContent = 'Search Student';
    }
  });

  resultsBody.addEventListener('click', async function (event) {
    var button = event.target.closest('.manage-btn');
    if (!button) return;
    clearAlert(manageAlert);
    button.disabled = true;
    button.textContent = 'Loading...';
    try {
      var payload = await loadStudent(button.dataset.id);
      selectedStudent = payload.result;
      if (managePanel) managePanel.classList.remove('d-none');
      renderStudentInfo(selectedStudent);
      if (currentPhoto) {
        if (selectedStudent.photo_url) appendImage(currentPhoto, selectedStudent.photo_url, 'Current student photo');
        else appendNoPhoto(currentPhoto, 'No student photo uploaded');
      }
      if (removePhoto) removePhoto.classList.toggle('d-none', !selectedStudent.photo_url);
      clearSelectedFile();
      if (managePanel) managePanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
    } catch (err) {
      setAlert(searchAlert, 'danger', err.message || 'Student record was not found.');
    } finally {
      button.disabled = false;
      button.textContent = 'Manage Photo';
    }
  });

  if (photoInput) {
    photoInput.addEventListener('change', function () {
      clearAlert(manageAlert);
      var file = photoInput.files && photoInput.files[0];
      if (!file) return clearSelectedFile();
      if (file.size > 2097152) { setAlert(manageAlert, 'danger', 'The selected image must not exceed 2 MB.'); return clearSelectedFile(); }
      if (['image/jpeg', 'image/png', 'image/webp'].indexOf(file.type) < 0) { setAlert(manageAlert, 'danger', 'Please select a valid image file.'); return clearSelectedFile(); }
      var reader = new FileReader();
      reader.onload = function (event) { if (newPreview) appendImage(newPreview, event.target.result, 'New photo preview'); };
      reader.readAsDataURL(file);
    });
  }

  if (clearSelection) clearSelection.addEventListener('click', clearSelectedFile);
  if (cancelManage) cancelManage.addEventListener('click', function () { clearSelectedFile(); if (managePanel) managePanel.classList.add('d-none'); });

  if (photoForm) {
    photoForm.addEventListener('submit', async function (event) {
      event.preventDefault();
      clearAlert(manageAlert);
      if (!selectedStudent) return;
      var file = photoInput && photoInput.files && photoInput.files[0];
      if (!file) return setAlert(manageAlert, 'warning', 'Please select a valid image file.');
      if (savePhoto) { savePhoto.disabled = true; savePhoto.textContent = 'Saving...'; }
      try {
        var payload = await saveStudentPhoto(selectedStudent.id, file);
        setAlert(manageAlert, 'success', payload.message || payload.sucMsg || 'Student photo updated successfully.');
        selectedStudent.photo_url = payload.result && payload.result.photo_url ? payload.result.photo_url : selectedStudent.photo_url;
        if (currentPhoto && selectedStudent.photo_url) appendImage(currentPhoto, selectedStudent.photo_url, 'Current student photo');
        if (removePhoto) removePhoto.classList.remove('d-none');
        clearSelectedFile();
      } catch (err) {
        setAlert(manageAlert, 'danger', err.message || 'Photo update failed. The existing photo was not changed.');
      } finally {
        if (savePhoto) { savePhoto.disabled = false; savePhoto.textContent = 'Save Photo'; }
      }
    });
  }

  if (removePhoto) {
    removePhoto.addEventListener('click', async function () {
      if (!selectedStudent || !confirm('Are you sure you want to remove this student’s photo?')) return;
      removePhoto.disabled = true;
      removePhoto.textContent = 'Removing...';
      try {
        var payload = await deleteStudentPhoto(selectedStudent.id);
        setAlert(manageAlert, 'success', payload.message || payload.sucMsg || 'Student photo removed successfully.');
        selectedStudent.photo_url = '';
        if (currentPhoto) appendNoPhoto(currentPhoto, 'No student photo uploaded');
        removePhoto.classList.add('d-none');
      } catch (err) {
        setAlert(manageAlert, 'danger', err.message || 'Server error.');
      } finally {
        removePhoto.disabled = false;
        removePhoto.textContent = 'Remove Photo';
      }
    });
  }
});
</script>
<%- include('system_layouts/s_foot') %>
